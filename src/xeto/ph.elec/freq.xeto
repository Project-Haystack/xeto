// Sensor for AC electric frequency
ElecAcFreqSensor : ElecSensor {
  freq
  unit: "Hz"
  ac
}

// Command for AC electric frequency
ElecAcFreqCmd : ElecCmd {
  freq
  unit: "Hz"
  ac
}
