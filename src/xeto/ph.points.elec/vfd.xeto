VfdOutput : PhEntity { vfd, output }

// Sensor for a VFD's output AC electric frequency
VfdOutputElecAcFreqSensor : VfdOutput & ElecAcFreqSensor

// Command for a VFD's output AC electric frequency
VfdOutputElecAcFreqCmd : VfdOutput & ElecAcFreqCmd
